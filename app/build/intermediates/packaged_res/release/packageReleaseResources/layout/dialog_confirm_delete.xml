<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Warning Icon -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"
        android:text="⚠️"
        android:textSize="48sp" />

    <!-- Warning Message -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="This action will permanently delete your account and all associated data. This cannot be undone!"
        android:textColor="@color/error_color"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center" />

    <!-- Confirmation Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Type 'DELETE' to confirm">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/confirmDeleteField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapCharacters" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Additional Warning -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="This will delete:\n• Your profile information\n• All attendance records\n• All subjects and data\n• Your account permanently"
        android:textColor="@color/secondary_text"
        android:textSize="12sp" />

</LinearLayout>
