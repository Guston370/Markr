<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Light gradient background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="@color/surface_color"
                android:centerColor="@color/surface_variant"
                android:endColor="@color/surface_color" />
        </shape>
    </item>
    
    <!-- Light top border -->
    <item android:top="0dp" android:bottom="-1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/primary_light" />
            <size android:height="2dp" />
        </shape>
    </item>
    
    <!-- Very light shadow -->
    <item android:top="0dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@color/shadow_light"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
