<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected/Checked state - Vibrant purple -->
    <item android:state_checked="true" android:color="@color/primary_color" />
    <item android:state_selected="true" android:color="@color/primary_color" />
    
    <!-- Pressed state - Lighter purple with glow effect -->
    <item android:state_pressed="true" android:color="@color/primary_light" />
    
    <!-- Focused state - Medium purple -->
    <item android:state_focused="true" android:color="@color/primary_variant" />
    
    <!-- Hover state - Subtle purple tint -->
    <item android:state_hovered="true" android:color="@color/primary_variant" />
    
    <!-- Default state - Dark gray for good contrast -->
    <item android:color="@color/secondary_text" />
</selector>
