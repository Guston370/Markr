<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - Modern Material Design 3 -->
    <style name="Base.Theme.Markr" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_light</item>
        <item name="colorOnPrimaryContainer">@color/primary_dark</item>

        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/secondary_color</item>
        <item name="colorSecondaryVariant">@color/secondary_dark</item>
        <item name="colorOnSecondary">@color/text_on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_light</item>
        <item name="colorOnSecondaryContainer">@color/secondary_dark</item>

        <!-- Tertiary Colors -->
        <item name="colorTertiary">@color/accent_color</item>
        <item name="colorOnTertiary">@color/white</item>
        <item name="colorTertiaryContainer">@color/accent_light</item>
        <item name="colorOnTertiaryContainer">@color/accent_dark</item>

        <!-- Background Colors -->
        <item name="android:colorBackground">@color/background_color</item>
        <item name="colorSurface">@color/surface_color</item>
        <item name="colorOnSurface">@color/primary_text</item>
        <item name="colorOnBackground">@color/primary_text</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/secondary_text</item>

        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/primary_text</item>
        <item name="android:textColorSecondary">@color/secondary_text</item>
        <item name="android:textColorTertiary">@color/tertiary_text</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/primary_color</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/surface_color</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Error Colors -->
        <item name="colorError">@color/error_color</item>
        <item name="colorOnError">@color/white</item>
        <item name="colorErrorContainer">@color/error_color</item>
        <item name="colorOnErrorContainer">@color/white</item>

        <!-- Outline Colors -->
        <item name="colorOutline">@color/border_color</item>
        <item name="colorOutlineVariant">@color/divider_color</item>

        <!-- Surface Tint -->
        <!-- <item name="colorSurfaceTint">@color/primary_color</item> -->
    </style>

    <style name="Theme.Markr" parent="Base.Theme.Markr" />

    <!-- Modern Button Styles -->
    <style name="ModernButton" parent="Widget.Material3.Button">
        <item name="android:layout_height">56dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:elevation">4dp</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="backgroundTint">@color/button_primary</item>
    </style>

    <style name="ModernButtonSecondary" parent="Widget.Material3.Button">
        <item name="android:layout_height">56dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:elevation">4dp</item>
        <item name="android:textColor">@color/text_on_secondary</item>
        <item name="backgroundTint">@color/button_secondary</item>
    </style>

    <style name="ModernOutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_height">56dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">16dp</item>
        <item name="strokeColor">@color/button_outline</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">@color/button_text</item>
    </style>

    <style name="ModernTextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:layout_height">48dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/button_text</item>
    </style>

    <!-- Modern Card Styles -->
    <style name="ModernCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">8dp</item>
        <item name="android:layout_margin">12dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>

    <style name="ModernCardFilled" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">4dp</item>
        <item name="android:layout_margin">12dp</item>
        <item name="cardBackgroundColor">@color/surface_variant</item>
    </style>

    <!-- Modern Text Styles - Maximum Visibility -->
    <style name="ModernTitle" parent="@android:style/Widget.TextView">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/primary_text</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:shadowColor">@color/shadow_light</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">2</item>
    </style>

    <style name="ModernSubtitle" parent="@android:style/Widget.TextView">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/primary_text</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:shadowColor">@color/shadow_light</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">2</item>
    </style>

    <style name="ModernBody" parent="@android:style/Widget.TextView">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/primary_text</item>
        <item name="android:lineSpacingExtra">4dp</item>
        <item name="android:shadowColor">@color/shadow_light</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0.5</item>
        <item name="android:shadowRadius">1</item>
    </style>

    <style name="ModernCaption" parent="@android:style/Widget.TextView">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/primary_text</item>
        <item name="android:lineSpacingExtra">2dp</item>
        <item name="android:shadowColor">@color/shadow_light</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0.5</item>
        <item name="android:shadowRadius">1</item>
    </style>

    <style name="ModernLabel" parent="@android:style/Widget.TextView">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/primary_text</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.5</item>
        <item name="android:shadowColor">@color/shadow_light</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0.5</item>
        <item name="android:shadowRadius">1</item>
    </style>

    <!-- Modern TextField Styles -->
    <style name="ModernTextField" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeColor">@color/border_color</item>
        <!-- <item name="boxStrokeColorFocused">@color/primary_color</item> -->
        <item name="hintTextColor">@color/secondary_text</item>
        <!-- <item name="hintTextColorFocused">@color/primary_color</item> -->
        <item name="android:textColorHint">@color/secondary_text</item>
    </style>

    <!-- Modern Bottom Navigation -->
    <style name="ModernBottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/surface_color</item>
        <item name="itemIconTint">@color/secondary_text</item>
        <item name="itemTextColor">@color/secondary_text</item>
        <item name="itemActiveIndicatorStyle">@style/ModernBottomNavIndicator</item>
    </style>

    <style name="ModernBottomNavIndicator" parent="@android:style/Widget">
        <item name="android:color">@color/primary_container</item>
        <item name="android:width">40dp</item>
        <item name="android:height">20dp</item>
        <item name="cornerRadius">10dp</item>
    </style>

    <!-- Bottom Navigation Text Styles - Professional & Modern -->
    <style name="BottomNavTextActive" parent="@android:style/Widget.TextView">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/primary_color</item>
    </style>

    <style name="BottomNavTextInactive" parent="@android:style/Widget.TextView">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/secondary_text</item>
    </style>

    <!-- Modern Floating Action Button -->
    <style name="ModernFAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_width">64dp</item>
        <item name="backgroundTint">@color/button_primary</item>
        <item name="tint">@color/text_on_primary</item>
        <item name="elevation">8dp</item>
        <item name="pressedTranslationZ">12dp</item>
    </style>

    <!-- Full Screen Dialog Style -->
    <style name="FullScreenDialog" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowBackground">@color/background_color</item>
        <item name="android:statusBarColor">@color/primary_color</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Modern Progress Bar -->
    <style name="ModernProgressBar" parent="Widget.Material3.LinearProgressIndicator">
        <item name="indicatorColor">@color/primary_color</item>
        <item name="trackColor">@color/surface_variant</item>
        <item name="trackThickness">4dp</item>
    </style>

    <!-- Modern Chip Styles -->
    <style name="ModernChip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">20dp</item>
        <item name="chipStrokeColor">@color/border_color</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/primary_text</item>
        <item name="chipBackgroundColor">@color/surface_color</item>
    </style>

    <style name="ModernChipSelected" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">20dp</item>
        <item name="chipStrokeColor">@color/primary_color</item>
        <item name="chipStrokeWidth">2dp</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="chipBackgroundColor">@color/primary_color</item>
    </style>
</resources>